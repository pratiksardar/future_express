# ─────────────────────────────────────────────────────────────────────────────
# SECURITY: Do NOT prefix any API keys or secrets with NEXT_PUBLIC_
# Next.js exposes only NEXT_PUBLIC_* to the browser. Keep all keys below
# without NEXT_PUBLIC_ so they stay server-only (Vercel, etc.).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/future_express

# ── AI / LLM providers ────────────────────────────────────────────────────────
# Provider priority (comma-separated, first = primary, rest = fallbacks).
# Only providers with keys set are attempted.
LLM_PROVIDER_PRIORITY=anthropic,openai,openrouter

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=sk-...
OPENAI_ARTICLE_MODEL=gpt-4o-mini

# OpenRouter — https://openrouter.ai (free model example shown)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# ── Inngest (background jobs & cron) ──────────────────────────────────────────
# Keys available in your Inngest dashboard: https://app.inngest.com
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
# Optional overrides
RESEND_FROM_ADDRESS=The Future Express <editor@thefutureexpress.com>
RESEND_REPLY_TO=editor@thefutureexpress.com

# ── Admin auth ────────────────────────────────────────────────────────────────
# Protects /api/admin/* endpoints. Pass as x-admin-key header.
# Generate with: openssl rand -hex 32
ADMIN_KEY=generate-a-strong-random-secret

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://thefutureexpress.com

# ── OG / Social ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_OG_IMAGE_URL=https://thefutureexpress.com/og.png

# ── Upstash Redis (optional — falls back to in-memory store if unset) ─────────
UPSTASH_REDIS_URL=https://...
UPSTASH_REDIS_TOKEN=...

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate keys ONCE per environment with: npx web-push generate-vapid-keys
# The public key is also exposed as NEXT_PUBLIC_ because PushManager.subscribe()
# requires applicationServerKey on the client. Private key is server-only.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Required by the VAPID spec: a mailto: or https: URI identifying the sender.
VAPID_SUBJECT=mailto:hello@thefutureexpress.com

# ── Hedera Consensus Service (publish receipts) ───────────────────────────────
# After every published edition the agent submits an edition_published message
# to a Hedera Consensus Service topic. The TX id is persisted on the editions
# row and surfaced on /transparency. Get a free testnet account + key at
# https://portal.hedera.com. Testnet HBAR is free.
# If any of these are unset, Hedera logging is silently skipped — the publish
# pipeline is unaffected.
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=
# Optional: pre-existing topic id (e.g. 0.0.4928421). When unset, the client
# lazily creates a new topic on first publish. Set this for stable operation so
# the topic survives process restarts.
HEDERA_TOPIC_ID=0.0.xxxxx
# Network: testnet | mainnet (client currently hardcodes testnet; update
# Client.forTestnet() in src/lib/blockchain/hedera/client.ts to switch)
HEDERA_NETWORK=testnet

# ── Ethereum / Base (agent identity & ERC-8021 payment trail) ─────────────────
# Server-side editor wallet address used for Base Mainnet royalty transactions.
EDITOR_WALLET_ADDRESS=0x...
# Expose same address to the browser for the identity strip.
NEXT_PUBLIC_EDITOR_WALLET_ADDRESS=0x...
# Minimum ETH balance required to run the edition pipeline (default: 0.001)
MIN_EDITOR_BALANCE_ETH=0.001
# Toggle to point CDP / Uniswap calls at testnets instead of mainnet.
USE_BASE_SEPOLIA=false
NEXT_PUBLIC_USE_BASE_SEPOLIA=false
USE_ETH_SEPOLIA=false
NEXT_PUBLIC_USE_ETH_SEPOLIA=false
# Optional: override RPC endpoint
# BASE_RPC_URL=https://mainnet.base.org

# ── Coinbase Developer Platform (optional) ────────────────────────────────────
# Used for Base / Coinbase integrations. Get keys at https://portal.cdp.coinbase.com
# CDP_PROJECT_ID=
# CDP_API_KEY_NAME=
# CDP_API_KEY_PRIVATE_KEY=

# ── Uniswap API ───────────────────────────────────────────────────────────────
# Required for the article swap widget. Key at https://developers.uniswap.org
UNISWAP_API_KEY=

# ── Market data ───────────────────────────────────────────────────────────────
# Kalshi API key for prediction market ingestion
KALSHI_API_KEY=
# Affiliate URL suffixes for external links (optional)
NEXT_PUBLIC_POLYMARKET_AFFILIATE_URL=https://polymarket.com
NEXT_PUBLIC_KALSHI_AFFILIATE_URL=https://kalshi.com

# ── Web research (article background context) ─────────────────────────────────
# Brave Search — https://brave.com/search/api
BRAVE_API_KEY=
# Tavily Search — fallback research provider — https://tavily.com
TAVILY_API_KEY=

# ── Edition pipeline tuning ───────────────────────────────────────────────────
# How many top-volume markets to pick per source (Polymarket + Kalshi).
# Default: 15, range 1–50. Increase as traction grows.
# EDITION_TOP_NEWS_PER_SOURCE=15

# ── Newsletter / community ────────────────────────────────────────────────────
NEXT_PUBLIC_SUBSTACK_URL=https://yourname.substack.com
NEXT_PUBLIC_BEEHIIV_URL=

# ── Ads ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AD_SLOT_ID=

# ── Playcard behaviour ────────────────────────────────────────────────────────
# Controls the call-to-action shown on social playcards: subscribe | predict
PLAYCARD_CTA_MODE=subscribe

# ── Feature flags (all default to disabled) ───────────────────────────────────
FF_AUTOMATED_BREAKING=false
FF_FALLBACK_IMAGE_API=false
FF_MOCK_X402=false
NEXT_PUBLIC_FF_BETA_UI=false

# ── Logging ───────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ── Internal API (server-to-server, optional) ─────────────────────────────────
API_BASE_URL=http://localhost:3000
API_PORT=3000
